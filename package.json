{
  "name": "ai-memory",
  "version": "0.1.0",
  "description": "Deterministic zero-token code memory generator",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "ai-memory": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "memory",
    "ast",
    "developer-tools",
    "ai-coding",
    "code-review",
    "static-analysis",
    "anti-hallucination",
    "deterministic",
    "zero-token"
  ],
  "dependencies": {
    "@babel/parser": "^7.26.5",
    "@babel/types": "^7.26.5",
    "commander": "^12.1.0",
    "ignore": "^5.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.5",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "resolutions": {
    "@babel/parser": "^7.26.5"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaungzawthant/Memo-log.git"
  },
  "homepage": "https://github.com/kaungzawthant/Memo-log#readme",
  "bugs": {
    "url": "https://github.com/kaungzawthant/Memo-log/issues"
  },
  "author": "kaungzawthant"
}
